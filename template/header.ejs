<header id="headerPage">
	<div class="頁首">
		<h1 class="big-title"><a href="/home">
				<%= heading %>
			</a></h1>
		<label class="switch" id="dark-mode">
			<input type="checkbox" onclick="darkmode()" title="dark mode" placeholder="" />
			<span class="slider round"></span>
		</label>
	</div>
	<nav class="導航欄">
		<button class="hamburger" onclick="toggleMenu()">☰</button>
		<ul class="nav-menu">
			<li><a href="/team_intro">關於團隊</a></li>
			<li><a href="/mini_game">小遊戲</a></li>
			<li><a href="/tools">工具</a></li>
			<li><a href="/tutorials">教學</a></li>
			<li><a href="/login">管理員登入</a></li>
		</ul>
		<div class="menu-overlay"></div>
	</nav>

	<!--
	<nav class="導航欄">
        <button onclick="window.location.href='/team_intro';">關於團隊</button>
        <button onclick="window.location.href='/mini_game';">小遊戲</button>
        <button onclick="window.location.href='/tools';">工具</button>
        <button onclick="window.location.href='/tutorials';">教學</button>
        <button onclick="window.location.href='/login';">管理員登入</button>
    </nav> -->
</header>
<script>
	function toggleMenu() {
		const menu = document.querySelector('.nav-menu');
		const overlay = document.querySelector('.menu-overlay');
		const darkmode_button = document.querySelector('#dark-mode');
		menu.classList.toggle('active');
		overlay.classList.toggle('active');
		darkmode_button.classList.toggle('active');
	}

	// 點擊外部關閉（點擊遮罩）
	document.querySelector('.menu-overlay').addEventListener('click', function () {
		document.querySelector('.nav-menu').classList.remove('active');
		document.querySelector('.menu-overlay').classList.remove('active');
		document.querySelector('#dark-mode').classList.remove('active');
	});

	// 點擊連結關閉
	document.querySelectorAll('.nav-menu a').forEach(link => {
		link.addEventListener('click', () => {
			document.querySelector('.nav-menu').classList.remove('active');
			document.querySelector('.menu-overlay').classList.remove('active');
			document.querySelector('#dark-mode').classList.remove('active');
		});
	});
</script>
<style>
	.導航欄 {
		display: flex;
		position: relative;
		height: 60px;
		background-color: var(--navi-color);

		.nav-menu {
			/*share on both platforms*/
			list-style: none;

			align-items: center;
			margin: 0px;
			padding: 0px;
			height: 100%;
			width: 100%;
			display: flex;
			flex-direction: row;

			li {
				width: 100%;
				height: 100%;
				display: flex;
				flex-direction: column;


				a {
					display: flex;
					align-items: center;
					justify-content: center;
					width: 100%;
					height: 100%;
					text-align: center;
					background-color: var(--navi-color);
					color: var(--text-color);
					border-radius: 0px 0px 0px 0px;
					text-decoration-line: none;
				}

				a:hover {
					background-color: var(--navi-hover-color);
					color: var(--text-color);
					cursor: pointer;
				}
			}
		}
	}

	.hamburger {
		display: none;
	}



	@media (max-width: 768px) {

		.導航欄 {
			position: fixed;
			display: flex;
			right: 10px;
			top: 10px;
			width: 50px;
			height: 50px;
			justify-content: center;
			border-radius: 12%;

			.nav-menu {
				position: fixed;
				top: 0;
				right: -30%;
				width: 30vw;
				height: 100vh;
				background-color: var(--navi-color);
				flex-direction: column;
				justify-content: center;
				align-items: last baseline;
				box-shadow: -5px 0 20px rgba(0, 0, 0, 0.3);
				z-index: 1;
				transition-duration: 0.3s;
				transform: translateX(100%);


				li {
					text-align: center;
					height: auto;
					width: 100%;
				}

				a {
					display: flex;
					justify-content: right;
					align-items: right;
					border: none;
					background: none;
					color: white;
					font-size: 25px;
					padding: 15px 20px;
				}
			}
		}

		.hamburger {
			align-items: center;
			justify-content: center;
			display: block;
			background: none;
			border: none;
			font-size: 24px;
			cursor: pointer;
			color: var(--text-color);
		}

		.nav-menu.active {
			right: 0;
			transition-duration: 0.3s;
			transform: translateX(0)
		}

		/* 新增遮罩層 */
		.menu-overlay {
			display: none;
			position: fixed;
			top: 0;
			left: 0;
			width: 100vw;
			height: 100vh;
			background: rgba(0, 0, 0, 0.5);
			z-index: 0;
		}

		.menu-overlay.active {
			display: block;
		}

		/* dark mode */
		#dark-mode {
			/* switch style*/
			position: fixed;
			right: 10px;
			transform: translateX(120%);
			transition-duration: 0.3s;
			top: 10px;
			z-index: 1;
		}

		#dark-mode.active {
			right: 10px;
			transform: translateX(0px);
			transition-duration: 0.3s;
		}
	}

	.big-title {
		animation-name: title-slide-in;
		animation-duration: 3s;
		animation-iteration-count: 1;
		position: relative;
		left: 20px;
		width: 400px;

		a {
			color: var(--text-color);
			text-decoration-line: none;
		}
	}

	/* dark mode */
	#dark-mode {
		/* switch style*/
		position: fixed;
		right: 10px;
		top: 10px;
		z-index: 1;
	}
</style>